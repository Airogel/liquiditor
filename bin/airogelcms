  puts "                        --name, --email, --password, --account_name required"
  puts "                        --api_url optional (default: https://api.airogelcms.com)"
  puts "  list_plans          - List available subscription plans"
  puts "                        --interval=month|year optional"
  puts "  create_account      - Create an additional account (--name required)"
  puts "  subscription_checkout - Get a Stripe Checkout URL to subscribe"
  puts "                        --plan required (plan prefix ID from list_plans)"
  puts "                        --success_url, --cancel_url optional"
  puts "  subscription_status - Check whether the account has an active subscription"
