#!/usr/bin/env ruby
# frozen_string_literal: true

# CLI wrapper for AirogelCmsClient
# Usage: bin/airogelcms <theme_name> <action> [options]
#
# Actions:
#   # Account creation & subscription (no theme directory required)
#   register            - Create new user + account + API token
#                         (--name, --email, --password, --account_name required;
#                          --api_url optional, defaults to https://api.airogelcms.com)
#                         Outputs credentials to write into themes/<theme>/.env
#   list_plans          - List available subscription plans
#                         (--api_url and --api_key required, or use theme .env)
#
#   # Account & subscription management (requires theme .env with API token)
#   create_account      - Create an additional account for the authenticated user
#                         (--name required)
#   subscription_checkout - Generate a Stripe Checkout URL to subscribe an account
#                         (--plan required; --success_url, --cancel_url optional)
#   subscription_status - Check whether the account has an active subscription
#
#   # Theme operations
#   download_theme      - Download entire theme (database + templates + assets)
#   download_database   - Download just database.yml
#   download_templates  - Download just templates
#   download_assets     - Download just assets
#   upload_theme        - Upload entire theme (templates + assets)
#   upload_templates    - Upload just templates
#   upload_assets       - Upload just assets
#
#   # List operations
#   list_accounts       - List available CMS accounts
#   list_templates      - List templates for the account
#   list_assets         - List assets for the account
#   list_collections    - List collections
#   list_entries        - List entries in a collection (--collection required)
#   list_blueprints     - List blueprints
#   list_navigations    - List navigations
#   list_globals        - List globals
#
#   # CRUD operations (use --key=value for options)
#   get_collection      - Get collection by ID or handle (--id required)
#   create_collection   - Create a collection (--name, --handle required)
#   update_collection   - Update a collection (--id required)
#   delete_collection   - Delete a collection (--id required)
#
#   get_entry           - Get entry by ID or handle (--collection, --id required)
#   create_entry        - Create an entry (--collection required, fields as options)
#   update_entry        - Update an entry (--collection, --id required)
#   delete_entry        - Delete an entry (--collection, --id required)
#
#   get_blueprint       - Get blueprint by ID or handle (--id required)
#   create_blueprint    - Create a blueprint (--handle, --title required, --fields JSON)
#   update_blueprint    - Update a blueprint (--id required)
#   delete_blueprint    - Delete a blueprint (--id required)
#
#   get_navigation      - Get navigation by ID or handle (--id required)
#   create_navigation   - Create a navigation (--handle, --title required)
#   update_navigation   - Update a navigation (--id required)
#   delete_navigation   - Delete a navigation (--id required)
#
#   get_global          - Get global by ID or handle (--id required)
#   create_global       - Create a global (--handle, --title required)
#   update_global       - Update a global (--id required)
#   delete_global       - Delete a global (--id required)
#
#   # WordPress import tools
#   parse_wordpress     - Parse WordPress XML export (--file required, --type optional)
#
#   # Asset tools
#   download_remote_asset - Download asset from URL (--url required)
#   extract_asset_urls    - Extract asset URLs from HTML (--html or --file required)

require_relative "../airogel_cms_client"
