  puts "  update_global       - Update global (--id required)"
  puts "  delete_global       - Delete global (--id required)"
  puts ""
  puts "WordPress Import:"
  puts "  parse_wordpress     - Parse WordPress XML (--file required, --type optional)"
  puts ""
  puts "Asset Tools:"
  puts "  download_remote_asset - Download remote asset (--url required)"
  puts "  extract_asset_urls    - Extract URLs from HTML (--html or --file required)"
  puts ""
  puts "Options:"
  puts "  --key=value         Pass options as key=value pairs"
  puts "  --json              Force JSON output"
  puts ""
  puts "Examples:"
  puts '  bin/airogelcms mysite register --name="Jane Doe" --email=jane@example.com \\'
  puts '    --password=secret123 --account_name="Jane\'s Site"'
