# Actions that do NOT require a theme directory or .env credentials.
# They take --api_url directly (defaulting to https://api.airogelcms.com).
NO_THEME_ACTIONS = %w[register].freeze

# Actions that require an API token but NOT necessarily an account_id from
# .env — the account_id is either in the response (register) or passed as
# --account_id / inferred from the theme.
NO_ACCOUNT_ACTIONS = %w[register list_plans create_account].freeze

